PORT=4000
PUBLIC_BASE_URL=http://localhost:4000

# InsForge database — get keys with: npx @insforge/cli secrets get ANON_KEY
INSFORGE_URL=https://your-appkey.us-east.insforge.app
INSFORGE_API_KEY=
INSFORGE_ANON_KEY=

# Sendblue outbound texting. Leave blank to run in demo mode.
SENDBLUE_API_KEY=
SENDBLUE_API_SECRET=
SENDBLUE_FROM_NUMBER=

# Nia semantic memory. Leave blank to disable Nia writes/searches.
NIA_API_KEY=

# Hyperspell connected account sync. Leave blank to disable.
HYPERSPELL_API_KEY=
HYPERSPELL_SYNC_HOURS=6

# Tensorlake background agents. Leave blank to use in-process intervals.
TENSORLAKE_API_KEY=
AGENT_AUTH_TOKEN=

# Agent timing.
AGENT_POLL_SECONDS=30
MEDICATION_FOLLOW_UP_MINUTES=15
MEDICATION_ESCALATION_MINUTES=30
