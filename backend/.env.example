PORT=4000
PUBLIC_BASE_URL=http://localhost:4000

# Sendblue outbound texting. Leave blank to run in demo mode.
SENDBLUE_API_KEY=
SENDBLUE_API_SECRET=
SENDBLUE_FROM_NUMBER=

# Nia semantic memory. Leave blank to disable Nia writes/searches.
NIA_API_KEY=

# Agent timing.
AGENT_POLL_SECONDS=30
MEDICATION_FOLLOW_UP_MINUTES=15
MEDICATION_ESCALATION_MINUTES=30
