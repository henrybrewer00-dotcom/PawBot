{
  "manifest_version": 3,
  "name": "Pawbot Browser",
  "version": "0.1.0",
  "description": "Pawbot's browser helper — describe what you want done in plain words, Pawbot drives the page for you.",
  "minimum_chrome_version": "120",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Pawbot Browser"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "options_page": "options/options.html",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "notifications",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
